  "tree": {
    "root": {
      "prompt": "Explore developer tools?",
      "choices": [
        { "label": "Show tool repos", "hint": "Card, Row, Text", "segment": "tools-overview", "next": "after-tools-overview" }
      ]
    },
    "after-tools-overview": {
      "prompt": "Browse by category?",
      "choices": [
        { "label": "View categories", "hint": "Tabs, Column, Text", "segment": "tools-tabs", "next": null }
      ]
    }
  }
}
