              },
              {
                "id": "tab-orch-text",
                "component": { "Text": { "text": { "literal": "polyforge-orchestrator, rtk" }, "usageHint": "body" } }
              },
              {
                "id": "tab-plugins",
                "component": {
                  "Column": {
                    "children": { "explicitList": ["tab-plugins-text"] }
                  }
                }
              },
              {
                "id": "tab-plugins-text",
                "component": { "Text": { "text": { "literal": "claude-code-plugins, agenthud-agui-a2ui" }, "usageHint": "body" } }
              },
              {
                "id": "tab-config",
                "component": {
                  "Column": {
                    "children": { "explicitList": ["tab-config-text"] }
                  }
                }
              },
              {
                "id": "tab-config-text",
                "component": { "Text": { "text": { "literal": "dotfiles, devcontainer templates" }, "usageHint": "body" } }
              }
            ]
          }
        }
      ]
