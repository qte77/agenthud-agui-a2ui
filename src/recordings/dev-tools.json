      "delayMs": 0,
      "type": "RUN_STARTED"
    },
    {
      "delayMs": 300,
      "type": "TEXT_MESSAGE_START"
    },
    {
      "delayMs": 50,
      "type": "TEXT_MESSAGE_CONTENT",
      "text": "Exploring developer tools across the qte77 portfolio..."
    },
    {
      "delayMs": 50,
      "type": "TEXT_MESSAGE_END"
    },
    {
      "delayMs": 500,
      "type": "STEP_STARTED",
      "text": "Fetching devtool repositories",
      "segment": "tools-overview"
