                "component": { "Text": { "text": { "literal": "claude-code-plugins" }, "usageHint": "h2" } }
              },
              {
                "id": "cc-desc",
                "component": { "Text": { "text": { "literal": "Plugin marketplace — 15 plugins, 31+ skills for Claude Code workflows." }, "usageHint": "body" } }
              },
              {
                "id": "cc-langs",
                "component": {
                  "Row": {
                    "children": { "explicitList": ["cc-l1", "cc-l2"] }
                  }
                }
              },
              {
                "id": "cc-l1",
                "component": { "Text": { "text": { "literal": "Markdown" }, "usageHint": "caption" } }
              },
              {
                "id": "cc-l2",
                "component": { "Text": { "text": { "literal": "Bash" }, "usageHint": "caption" } }
              },
              {
                "id": "card-dotfiles",
                "component": {
                  "Card": {
                    "children": { "explicitList": ["df-title", "df-desc", "df-langs"] }
                  }
                }
              },
              {
                "id": "df-title",
                "component": { "Text": { "text": { "literal": "dotfiles" }, "usageHint": "h2" } }
              },
              {
                "id": "df-desc",
                "component": { "Text": { "text": { "literal": "Personal dev environment — shell config, aliases, tool defaults." }, "usageHint": "body" } }
              },
