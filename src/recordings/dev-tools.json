    {
      "delayMs": 200,
      "type": "TOOL_CALL_END"
    },
    {
      "delayMs": 200,
      "type": "STEP_FINISHED"
    },
    {
      "delayMs": 300,
      "type": "TEXT_MESSAGE_START"
    },
    {
      "delayMs": 50,
      "type": "TEXT_MESSAGE_CONTENT",
      "text": "Developer tools overview complete. Three repos shown as cards, three category tabs for browsing by concern."
    },
    {
      "delayMs": 50,
      "type": "TEXT_MESSAGE_END"
    },
    {
      "delayMs": 100,
      "type": "RUN_FINISHED"
    }
